# ============================================================
# Agentic RAG 环境变量配置
# 复制此文件为 .env 并根据需要修改
# ============================================================

# --- Ollama 服务 ---
OLLAMA_HOST=http://localhost:11434

# --- Embedding 模型 ---
# 可选: embeddinggemma:latest, nomic-embed-text:latest, bge-m3:latest
EMBEDDING_MODEL=embeddinggemma:latest
EMBEDDING_DIMENSIONS=768

# --- 生成模型 (LLM) ---
# 可选: llama3.2:latest, qwen2.5:latest, deepseek-r1:latest, phi-4:latest
LLM_MODEL=llama3.2:latest

# --- LanceDB 存储路径 ---
LANCEDB_URI=data/lancedb
LANCEDB_TABLE_NAME=knowledge_base

# --- Streamlit ---
STREAMLIT_PORT=8501
STREAMLIT_TITLE=Agentic RAG with EmbeddingGemma (100% Local)

# --- 文档处理 ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Agent ---
AGENT_DEBUG_MODE=false

# --- 模型 keep_alive (模型在内存中驻留时间) ---
KEEP_ALIVE=5m

# --- Reranker (Cross-Encoder 重排序) ---
# 轻量英文模型 (~87MB): cross-encoder/ms-marco-MiniLM-L-6-v2
# 多语言强大模型 (~2.3GB): BAAI/bge-reranker-v2-m3
# 多语言平衡模型 (~280MB): mixedbread-ai/mxbai-rerank-xsmall-v1
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# 重排序后保留的文档数
RERANKER_TOP_N=5
# 初始向量检索数量（重排序前的候选集大小）
RETRIEVAL_TOP_K=20
# 是否启用 reranker (true / false)
RERANKER_ENABLED=true

# --- 文件上传 ---
UPLOAD_DIR=data/uploads

# --- 对话记忆 ---
# 是否启用多轮对话记忆（true / false）
ENABLE_CONVERSATION_MEMORY=true
# 每次请求携带的历史轮次数（0 = 所有历史）
NUM_HISTORY_RUNS=10
# SQLite 数据库路径（用于持久化 session 和对话历史）
DB_PATH=data/sessions.db

# --- 工具调用 (Function Calling) ---
# 是否启用 Agent 工具调用能力（true / false）
# 工具包括：网页搜索、数学计算、获取时间
ENABLE_TOOLS=true
# 排除的工具（逗号分隔），留空 = 启用全部
# 示例: "search_web" 表示禁用网页搜索
TOOLS_EXCLUDE=

# --- ReAct 推理可视化 ---
# 是否在 UI 中展示 Agent 的推理过程（思考→行动→观察→回答）
SHOW_REACT_PROCESS=true
